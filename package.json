{
  "name": "theshook.one",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "astro:dev": "astro dev",
    "astro:build": "astro build",
    "astro:preview": "astro preview",
    "astro": "astro",
    "format": "prettier --write .",
    "dev": "wrangler types && npm run astro:build && wrangler dev --test-scheduled",
    "kv:update": "curl \"http://localhost:8787/__scheduled?cron=0+*+*+*+*\""
  },
  "dependencies": {
    "@astrojs/cloudflare": "13.6.1",
    "astro": "6.4.3",
    "fast-xml-parser": "5.8.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260603.1",
    "prettier": "3.8.3",
    "prettier-plugin-astro": "0.14.1",
    "wrangler": "4.97.0"
  }
}
